# =========================================================
# APP
# =========================================================
ASPNETCORE_ENVIRONMENT=Production
ENABLE_DOCS=false

# =========================================================
# DATABASE - MONGODB
# =========================================================
MONGO_DATABASE=chat-db
MONGO_CONNECTION_STRING=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# =========================================================
# CACHE - REDIS
# =========================================================
REDIS_CONNECTION_STRING=rediss://default:<password>@<host>:6379

# =========================================================
# MESSAGE BROKER - RABBITMQ
# =========================================================
RABBITMQ_USER=<rabbitmq-user>
RABBITMQ_PASS=<rabbitmq-password>
RABBITMQ_CONNECTION_STRING=amqps://<user>:<password>@<host>/<vhost>

# =========================================================
# AUTHENTICATION - JWT
# =========================================================
JWT_KEY=<strong-rsa-or-secret-key>
JWT_ISSUER=uni-chat
JWT_AUDIENCE=uni-chat-users
JWT_EXPIRE_MINUTES=15

# =========================================================
# REFRESH TOKENS
# =========================================================
REFRESH_EXPIRE_DAYS=7

# =========================================================
# FILE STORAGE - CLOUDINARY
# =========================================================
CLOUDINARY_CLOUD_NAME=<cloud-name>
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_API_SECRET=<api-secret>

# =========================================================
# MONGO EXPRESS (Optional Admin Panel)
# =========================================================
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASS=<strong-password>

# =========================================================
# LOGGING - SEQ
# =========================================================
SEQ_ADMIN=admin
SEQ_ADMIN_PASSWORD=<strong-password>